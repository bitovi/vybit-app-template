{
	"servers": {
		"playwright": {
			"command": "npx",
			"args": [
				"-y",
				"@playwright/mcp@latest",
				"--browser",
				"chromium",
				"--no-sandbox",
				"--caps=vision"
			],
			"type": "stdio"
		},
		"filesystem": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"${workspaceFolder}"
			],
			"type": "stdio"
		},
		"atlassian": {
			"url": "https://mcp.atlassian.com/v1/mcp",
			"type": "http"
		}
	},
	"inputs": []
}