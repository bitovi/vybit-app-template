{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run App (Dev Server)",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": ".",
          "file": 1,
          "message": 0
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE.*ready in",
          "endsPattern": "(Local|Network):.*"
        }
      },
      "group": { "kind": "build", "isDefault": false }
    },
    {
      "label": "Run Storybook",
      "type": "shell",
      "command": "npm run storybook",
      "isBackground": true
    },
    {
      "label": "Build App",
      "type": "shell",
      "command": "npm run build",
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}
